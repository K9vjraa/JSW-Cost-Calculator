generator client {
  provider = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
}

enum CalculationStatus {
  DRAFT
  SUBMITTED
  APPROVED
  COMPLETED
  CANCELLED
}

enum NotificationPriority {
  LOW
  MEDIUM
  HIGH
}

enum DepartmentType {
  COSTING
  PDQC
}

model User {
  id                         String                @id @db.Uuid
  name                       String                @map("full_name")
  email                      String                @unique
  department                 DepartmentType?
  passwordHash               String?
  status                     String                @default("ACTIVE")
  role                       String
  alloys                     Alloy[]
  calculations               Calculation[]
  auditLogs                  AuditLog[]
  notifications              Notification[]
  reports                    Report[]
  priceHistoryEvents         PriceHistory[]
  approvedCalculations       Calculation[]         @relation("ApprovedCalculations")
  createdAt                  DateTime              @default(now()) @map("created_at")
  updatedAt                  DateTime              @updatedAt @map("updated_at")
  rawMaterialsCreated        RawMaterial[]         @relation("MaterialCreatedBy")
  rawMaterialsUpdated        RawMaterial[]         @relation("MaterialUpdatedBy")
  materialPriceHistories     MaterialPriceHistory[] @relation("MaterialPriceHistoryUpdater")
  materialAuditLogs          MaterialAuditLog[]     @relation("MaterialAuditLogUser")
  createdGrades              Grade[]               @relation("CreatedGrades")
  updatedGrades              Grade[]               @relation("UpdatedGrades")
  approvedGrades             Grade[]               @relation("ApprovedGrades")
  gradeVersionsCreated       GradeVersion[]        @relation("CreatedGradeVersions")
  gradeVersionsApproved      GradeVersion[]        @relation("ApprovedGradeVersions")
  gradeHistories             GradeHistory[]
  gradeValidationLogs        GradeValidationLog[]
  createdComparisonSessions  ComparisonSession[]   @relation("CreatedComparisonSessions")
  updatedComparisonSessions  ComparisonSession[]   @relation("UpdatedComparisonSessions")
  createdComparisonSnapshots ComparisonSnapshot[]  @relation("CreatedComparisonSnapshots")
  createdComparisonNotes     ComparisonNote[]      @relation("CreatedComparisonNotes")
  updatedComparisonNotes     ComparisonNote[]      @relation("UpdatedComparisonNotes")
  comparisonHistories        ComparisonHistory[]   @relation("PerformedComparisonHistories")
  comparisonExports          ComparisonExport[]    @relation("ExportedComparisonExports")
  comparisonPreference       ComparisonPreference?

  @@index([createdAt])
  @@map("profiles")
}

model Metal {
  id               String            @id @default(uuid())
  name             String
  code             String            @unique
  category         String
  unit             String            @default("kg")
  status           String            @default("ACTIVE")
  description      String?
  grades           Grade[]
  alloyComponents  AlloyComponent[]
  prices           PriceList[]
  priceHistory     PriceHistory[]
  calculationItems CalculationItem[]
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  @@index([name])
  @@index([category, status])
  @@index([createdAt])
}

model Grade {
  id                   String               @id @default(uuid())
  metalId              String
  metal                Metal                @relation(fields: [metalId], references: [id], onDelete: Cascade)
  code                 String?              @unique
  name                 String
  subGrade             String?
  category             String?
  steelType            String?
  targetBatchQty       Int?
  description          String?
  version              Int                  @default(1)
  status               String               @default("DRAFT")
  submittedAt          DateTime?
  approvedAt           DateTime?
  approvedById         String?              @db.Uuid
  approvedBy           User?                @relation("ApprovedGrades", fields: [approvedById], references: [id])
  publishedAt          DateTime?
  createdById          String?              @db.Uuid
  createdBy            User?                @relation("CreatedGrades", fields: [createdById], references: [id])
  updatedById          String?              @db.Uuid
  updatedBy            User?                @relation("UpdatedGrades", fields: [updatedById], references: [id])
  multiplier           Decimal              @db.Decimal(10, 4)
  extraPrice           Decimal              @default(0) @db.Decimal(14, 2)
  mechanicalProperties Json
  toleranceProperties  Json
  bendProperties       Json
  chemicalComposition  Json
  alloyComponents      AlloyComponent[]
  calculationItems     CalculationItem[]
  mechanicalProperty   MechanicalProperty?
  chemicalProperty     ChemicalProperty?
  gradeMaterials       GradeMaterial[]
  gradeVersions        GradeVersion[]
  gradeHistories       GradeHistory[]
  gradeValidationLogs  GradeValidationLog[]
  comparisonItems      ComparisonItem[]

  @@unique([metalId, name, subGrade])
  @@index([metalId, status])
  @@index([name])
  @@index([status])
}

model MaterialCategory {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  materials   RawMaterial[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@map("material_categories")
}

model MaterialSupplier {
  id          String   @id @default(uuid())
  code        String   @unique
  name        String
  contactName String?
  email       String?
  phone       String?
  status      String   @default("ACTIVE")
  materials   RawMaterial[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@map("material_suppliers")
}

model MaterialRate {
  id             String      @id @default(uuid())
  rawMaterialId  String
  rawMaterial    RawMaterial @relation(fields: [rawMaterialId], references: [id], onDelete: Cascade)
  rate           Decimal     @db.Decimal(16, 4)
  currency       String      @default("INR")
  effectiveFrom  DateTime
  effectiveTo    DateTime?
  isActive       Boolean     @default(true)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  
  @@index([rawMaterialId, isActive])
  @@map("material_rates")
}

model MaterialPriceHistory {
  id             String      @id @default(uuid())
  rawMaterialId  String
  rawMaterial    RawMaterial @relation(fields: [rawMaterialId], references: [id], onDelete: Cascade)
  oldRate        Decimal?    @db.Decimal(16, 4)
  newRate        Decimal     @db.Decimal(16, 4)
  currency       String      @default("INR")
  effectiveDate  DateTime
  reason         String?
  updatedById    String?     @db.Uuid
  updatedBy      User?       @relation("MaterialPriceHistoryUpdater", fields: [updatedById], references: [id])
  createdAt      DateTime    @default(now())
  
  @@index([rawMaterialId, createdAt])
  @@map("material_price_histories")
}

model MaterialAuditLog {
  id             String      @id @default(uuid())
  rawMaterialId  String
  rawMaterial    RawMaterial @relation(fields: [rawMaterialId], references: [id], onDelete: Cascade)
  action         String
  details        Json?
  userId         String?     @db.Uuid
  user           User?       @relation("MaterialAuditLogUser", fields: [userId], references: [id])
  createdAt      DateTime    @default(now())
  
  @@index([rawMaterialId, createdAt])
  @@map("material_audit_logs")
}

model RawMaterial {
  id               String            @id @default(uuid())
  materialCode     String            @unique @map("material_code")
  materialName     String            @map("material_name")
  categoryId       String?           @map("category_id")
  category         MaterialCategory? @relation(fields: [categoryId], references: [id])
  description      String?
  unit             String            @default("kg")
  supplierId       String?           @map("supplier_id")
  supplier         MaterialSupplier? @relation(fields: [supplierId], references: [id])
  currentRate      Decimal           @default(0) @db.Decimal(16, 4) @map("current_rate")
  currency         String            @default("INR")
  availability     Boolean           @default(true)
  isMicro          Boolean           @default(false) @map("is_micro")
  status           String            @default("ACTIVE")
  effectiveDate    DateTime          @default(now()) @map("effective_date")
  version          Int               @default(1)
  
  createdById      String?           @db.Uuid @map("created_by_id")
  createdBy        User?             @relation("MaterialCreatedBy", fields: [createdById], references: [id])
  updatedById      String?           @db.Uuid @map("updated_by_id")
  updatedBy        User?             @relation("MaterialUpdatedBy", fields: [updatedById], references: [id])
  
  createdAt        DateTime          @default(now()) @map("created_at")
  updatedAt        DateTime          @updatedAt @map("updated_at")

  rates            MaterialRate[]
  priceHistory     MaterialPriceHistory[]
  auditLogs        MaterialAuditLog[]

  alloyComponents  AlloyComponent[]
  calculationItems CalculationItem[]
  gradeMaterials   GradeMaterial[]
  prices           PriceList[]
  legacyHistory    PriceHistory[]

  @@index([materialName, availability])
  @@map("master_materials")
}

model Alloy {
  id           String           @id @default(uuid())
  name         String
  code         String           @unique
  type         String
  createdById  String?          @db.Uuid
  createdBy    User?            @relation(fields: [createdById], references: [id])
  components   AlloyComponent[]
  calculations Calculation[]
  status       String           @default("ACTIVE")
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  @@index([name, status])
}

model AlloyComponent {
  id                 String       @id @default(uuid())
  alloyId            String
  alloy              Alloy        @relation(fields: [alloyId], references: [id], onDelete: Cascade)
  metalId            String?
  metal              Metal?       @relation(fields: [metalId], references: [id])
  gradeId            String?
  grade              Grade?       @relation(fields: [gradeId], references: [id])
  rawMaterialId      String?
  rawMaterial        RawMaterial? @relation(fields: [rawMaterialId], references: [id])
  compositionPercent Decimal      @db.Decimal(7, 4)
  quantity           Decimal?     @db.Decimal(16, 4)
  createdAt          DateTime     @default(now())

  @@index([alloyId])
}

model Supplier {
  id          String      @id @default(uuid())
  name        String
  code        String      @unique
  contactName String?
  email       String
  phone       String?
  status      String      @default("ACTIVE")
  prices      PriceList[]
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@index([name, status])
}

model PriceList {
  id            String       @id @default(uuid())
  metalId       String?
  metal         Metal?       @relation(fields: [metalId], references: [id])
  rawMaterialId String?
  rawMaterial   RawMaterial? @relation(fields: [rawMaterialId], references: [id])
  supplierId    String?
  supplier      Supplier?    @relation(fields: [supplierId], references: [id])
  pricePerUnit  Decimal      @db.Decimal(16, 4)
  currency      String       @default("INR")
  unit          String       @default("kg")
  source        String
  location      String       @default("India")
  effectiveFrom DateTime
  active        Boolean      @default(true)
  status        String       @default("APPROVED")
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@index([metalId, active, effectiveFrom])
  @@index([rawMaterialId, active, effectiveFrom])
  @@index([supplierId])
}

model PriceHistory {
  id            String       @id @default(uuid())
  metalId       String?
  metal         Metal?       @relation(fields: [metalId], references: [id])
  rawMaterialId String?
  rawMaterial   RawMaterial? @relation(fields: [rawMaterialId], references: [id])
  oldPrice      Decimal?     @db.Decimal(16, 4)
  newPrice      Decimal      @db.Decimal(16, 4)
  updatedById   String       @db.Uuid
  updatedBy     User         @relation(fields: [updatedById], references: [id])
  reason        String?
  updatedAt     DateTime     @default(now())

  @@index([metalId, updatedAt])
  @@index([rawMaterialId, updatedAt])
}

model Calculation {
  id             String            @id @default(uuid())
  batchId        String            @unique
  mode           String
  name           String
  userId         String            @db.Uuid
  user           User              @relation(fields: [userId], references: [id])
  alloyId        String?
  alloy          Alloy?            @relation(fields: [alloyId], references: [id])
  totalQuantity  Decimal           @db.Decimal(16, 4)
  baseCost       Decimal           @db.Decimal(18, 4)
  gstAmount      Decimal           @default(0) @db.Decimal(18, 4)
  finalCost      Decimal           @db.Decimal(18, 4)
  snapshot       Json
  status         CalculationStatus @default(DRAFT)
  items          CalculationItem[]
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  completedAt    DateTime?
  oldCost        Decimal?          @db.Decimal(18, 4)
  approvedById   String?           @db.Uuid
  approvedBy     User?             @relation("ApprovedCalculations", fields: [approvedById], references: [id])
  approvedAt     DateTime?
  approvalReason String?

  @@index([userId, createdAt])
  @@index([status, createdAt])
  @@index([alloyId])
  @@index([createdAt])
  @@index([completedAt])
}

model CalculationItem {
  id              String       @id @default(uuid())
  calculationId   String
  calculation     Calculation  @relation(fields: [calculationId], references: [id], onDelete: Cascade)
  metalId         String?
  metal           Metal?       @relation(fields: [metalId], references: [id])
  rawMaterialId   String?
  rawMaterial     RawMaterial? @relation(fields: [rawMaterialId], references: [id])
  gradeId         String?
  grade           Grade?       @relation(fields: [gradeId], references: [id])
  itemName        String
  quantity        Decimal      @db.Decimal(16, 4)
  compositionPct  Decimal?     @db.Decimal(7, 4)
  gradeMultiplier Decimal      @db.Decimal(10, 4)
  snapshot        Json

  @@index([calculationId])
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String?  @db.Uuid
  user      User?    @relation(fields: [userId], references: [id])
  action    String
  entity    String?
  entityId  String?
  ipAddress String?
  details   Json?
  createdAt DateTime @default(now())

  @@index([entity, createdAt])
  @@index([userId, createdAt])
  @@index([createdAt])
}

model Notification {
  id        String               @id @default(uuid())
  userId    String?              @db.Uuid
  user      User?                @relation(fields: [userId], references: [id])
  title     String
  message   String
  category  String
  priority  NotificationPriority @default(MEDIUM)
  readAt    DateTime?
  createdAt DateTime             @default(now())

  @@index([userId, readAt, createdAt])
  @@index([category, createdAt])
  @@index([createdAt])
}

model Report {
  id            String   @id @default(uuid())
  name          String
  type          String
  filters       Json
  generatedById String   @db.Uuid
  generatedBy   User     @relation(fields: [generatedById], references: [id])
  calculationId String?
  createdAt     DateTime @default(now())

  @@index([type, createdAt])
}

/// Enterprise system settings – key/value store for runtime configuration
model SystemSetting {
  id          String   @id @default(uuid())
  key         String   @unique
  value       String
  label       String
  category    String   @default("GENERAL")
  description String?
  updatedById String?
  updatedAt   DateTime @updatedAt
  createdAt   DateTime @default(now())

  @@index([category])
}

/// GST slab rates applied to calculation final cost
model GstSlab {
  id          String   @id @default(uuid())
  name        String
  code        String   @unique
  rate        Decimal  @db.Decimal(7, 4)
  description String?
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model MechanicalProperty {
  id                 String   @id @default(uuid())
  gradeId            String   @unique
  grade              Grade    @relation(fields: [gradeId], references: [id], onDelete: Cascade)
  uts                String
  yieldStrength      String
  elongation         String
  hardness           String
  thicknessTolerance String
  widthTolerance     String
  flatnessTolerance  String
  minBendRadius      String
  bendRating         String
  springback         String
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model ChemicalProperty {
  id         String   @id @default(uuid())
  gradeId    String   @unique
  grade      Grade    @relation(fields: [gradeId], references: [id], onDelete: Cascade)
  carbon     String?
  manganese  String?
  silicon    String?
  chromium   String?
  nickel     String?
  molybdenum String?
  phosphorus String?
  sulfur     String?
  aluminum   String?
  magnesium  String?
  iron       String?
  copper     String?
  zinc       String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model ComparisonSession {
  id          String    @id @default(uuid())
  name        String
  description String?
  status      String    @default("ACTIVE")
  isFavorite  Boolean   @default(false)
  isArchived  Boolean   @default(false)
  tags        String[]  @default([])
  createdById String?   @db.Uuid
  createdBy   User?     @relation("CreatedComparisonSessions", fields: [createdById], references: [id])
  updatedById String?   @db.Uuid
  updatedBy   User?     @relation("UpdatedComparisonSessions", fields: [updatedById], references: [id])
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  items     ComparisonItem[]
  results   ComparisonResult[]
  snapshots ComparisonSnapshot[]
  notes     ComparisonNote[]
  histories ComparisonHistory[]
  exports   ComparisonExport[]

  @@index([createdById, status])
  @@index([createdAt])
  @@map("comparison_sessions")
}

model ComparisonItem {
  id                  String            @id @default(uuid())
  comparisonSessionId String
  comparisonSession   ComparisonSession @relation(fields: [comparisonSessionId], references: [id], onDelete: Cascade)
  gradeId             String
  grade               Grade             @relation(fields: [gradeId], references: [id], onDelete: Cascade)
  position            Int               @default(0)
  colorCode           String?
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
  deletedAt           DateTime?

  @@index([comparisonSessionId])
  @@index([gradeId])
  @@map("comparison_items")
}

model ComparisonResult {
  id                  String            @id @default(uuid())
  comparisonSessionId String
  comparisonSession   ComparisonSession @relation(fields: [comparisonSessionId], references: [id], onDelete: Cascade)
  metricsJson         Json
  costDifference      Decimal?          @db.Decimal(18, 4)
  varianceJson        Json?
  calculatedAt        DateTime          @default(now())

  @@index([comparisonSessionId])
  @@map("comparison_results")
}

model ComparisonSnapshot {
  id                  String            @id @default(uuid())
  comparisonSessionId String
  comparisonSession   ComparisonSession @relation(fields: [comparisonSessionId], references: [id], onDelete: Cascade)
  snapshotData        Json
  version             Int               @default(1)
  createdById         String?           @db.Uuid
  createdBy           User?             @relation("CreatedComparisonSnapshots", fields: [createdById], references: [id])
  createdAt           DateTime          @default(now())

  @@index([comparisonSessionId])
  @@map("comparison_snapshots")
}

model ComparisonNote {
  id                  String            @id @default(uuid())
  comparisonSessionId String
  comparisonSession   ComparisonSession @relation(fields: [comparisonSessionId], references: [id], onDelete: Cascade)
  content             String            @db.Text
  createdById         String?           @db.Uuid
  createdBy           User?             @relation("CreatedComparisonNotes", fields: [createdById], references: [id])
  updatedById         String?           @db.Uuid
  updatedBy           User?             @relation("UpdatedComparisonNotes", fields: [updatedById], references: [id])
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
  deletedAt           DateTime?

  @@index([comparisonSessionId])
  @@map("comparison_notes")
}

model ComparisonHistory {
  id                  String            @id @default(uuid())
  comparisonSessionId String
  comparisonSession   ComparisonSession @relation(fields: [comparisonSessionId], references: [id], onDelete: Cascade)
  action              String
  details             Json?
  performedById       String?           @db.Uuid
  performedBy         User?             @relation("PerformedComparisonHistories", fields: [performedById], references: [id])
  createdAt           DateTime          @default(now())

  @@index([comparisonSessionId, createdAt])
  @@map("comparison_history")
}

model ComparisonExport {
  id                  String            @id @default(uuid())
  comparisonSessionId String
  comparisonSession   ComparisonSession @relation(fields: [comparisonSessionId], references: [id], onDelete: Cascade)
  format              String
  fileUrl             String
  exportedById        String?           @db.Uuid
  exportedBy          User?             @relation("ExportedComparisonExports", fields: [exportedById], references: [id])
  createdAt           DateTime          @default(now())

  @@index([comparisonSessionId])
  @@map("comparison_exports")
}

model ComparisonPreference {
  id             String   @id @default(uuid())
  userId         String   @unique @db.Uuid
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  defaultMetrics Json?
  viewMode       String   @default("TABLE")
  theme          String   @default("LIGHT")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@map("comparison_preferences")
}

model JswProductCatalog {
  id        String   @id @default(uuid())
  category  String
  steelType String
  grade     String
  subGrade  String
  image     String
  basePrice Decimal  @db.Decimal(10, 4)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([category, steelType, grade, subGrade])
}

// ------------------------------------------------------------
// Grade Builder additional models
// ------------------------------------------------------------

model GradeMaterial {
  id                 String      @id @default(uuid())
  gradeId            String
  grade              Grade       @relation(fields: [gradeId], references: [id], onDelete: Cascade)
  materialId         String
  material           RawMaterial @relation(fields: [materialId], references: [id])
  compositionPercent Decimal     @db.Decimal(7, 4)
  quantityKg         Decimal?    @db.Decimal(16, 4)
  sortOrder          Int?        @default(0)
  remarks            String?
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt
  deletedAt          DateTime?
  status             String      @default("ACTIVE")

  @@unique([gradeId, materialId])
  @@index([gradeId])
}

model GradeVersion {
  id           String   @id @default(uuid())
  gradeId      String
  grade        Grade    @relation(fields: [gradeId], references: [id], onDelete: Cascade)
  version      Int
  status       String   @default("DRAFT")
  changeReason String?
  createdById  String   @db.Uuid
  createdBy    User     @relation("CreatedGradeVersions", fields: [createdById], references: [id])
  approvedById String?  @db.Uuid
  approvedBy   User?    @relation("ApprovedGradeVersions", fields: [approvedById], references: [id])
  snapshotJson Json
  createdAt    DateTime @default(now())

  @@index([gradeId, version])
}

model GradeHistory {
  id            String   @id @default(uuid())
  gradeId       String
  grade         Grade    @relation(fields: [gradeId], references: [id], onDelete: Cascade)
  action        String
  previousState Json
  newState      Json
  changedById   String   @db.Uuid
  changedBy     User     @relation(fields: [changedById], references: [id])
  createdAt     DateTime @default(now())

  @@index([gradeId, createdAt])
}

model GradeValidationLog {
  id            String   @id @default(uuid())
  gradeId       String
  grade         Grade    @relation(fields: [gradeId], references: [id], onDelete: Cascade)
  status        String
  errors        Json?
  validatedById String   @db.Uuid
  validatedBy   User     @relation(fields: [validatedById], references: [id])
  createdAt     DateTime @default(now())

  @@index([gradeId, status])
}
