# ╔══════════════════════════════════════════════════════════════════════════╗
# ║  JSW MCMS Backend — Production Environment Variables                    ║
# ║  Copy to .env and fill in real values. Never commit .env to git.        ║
# ╚══════════════════════════════════════════════════════════════════════════╝

# ── Database ─────────────────────────────────────────────────────────────────
# Neon PostgreSQL connection string (from Neon dashboard → Connection string)
# Format: postgresql://<user>:<password>@<host>/<dbname>?sslmode=require
DATABASE_URL="postgresql://mcms_owner:CHANGE_ME@ep-xxx.ap-southeast-1.aws.neon.tech/mcms?sslmode=require&connect_timeout=30&pool_timeout=10&connection_limit=10"

# ── JWT Secrets (generate with: openssl rand -base64 64) ─────────────────────
JWT_ACCESS_SECRET="REPLACE_WITH_64_CHAR_RANDOM_SECRET_ACCESS"
JWT_REFRESH_SECRET="REPLACE_WITH_64_CHAR_RANDOM_SECRET_REFRESH"

# ── Token TTLs ────────────────────────────────────────────────────────────────
ACCESS_TOKEN_TTL="15m"
REFRESH_TOKEN_TTL_DAYS="7"

# ── CORS Origin (Vercel production URL) ───────────────────────────────────────
CLIENT_ORIGIN="https://jsw-mcms.vercel.app"

# ── Server ────────────────────────────────────────────────────────────────────
PORT="4000"
NODE_ENV="production"

# ── Logging ───────────────────────────────────────────────────────────────────
# Levels: error | warn | info | http | debug
LOG_LEVEL="info"
