# ╔══════════════════════════════════════════════════════════════════════════╗
# ║  JSW MCMS Backend — Production Environment Variables                    ║
# ║  Copy to .env and fill in real values. Never commit .env to git.        ║
# ╚══════════════════════════════════════════════════════════════════════════╝

# ── Database ─────────────────────────────────────────────────────────────────
# Supabase connection strings (from Supabase Dashboard -> Settings -> Database -> Connection string)
# Format DATABASE_URL: Transaction Pooler URL (typically port 6543) with ?pgbouncer=true
DATABASE_URL="postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true"
# Format DIRECT_URL: Direct Database Connection URL (typically port 5432)
DIRECT_URL="postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres"

# ── JWT Secrets (generate with: openssl rand -base64 64) ─────────────────────
JWT_ACCESS_SECRET="REPLACE_WITH_64_CHAR_RANDOM_SECRET_ACCESS"
JWT_REFRESH_SECRET="REPLACE_WITH_64_CHAR_RANDOM_SECRET_REFRESH"

# ── Token TTLs ────────────────────────────────────────────────────────────────
ACCESS_TOKEN_TTL="15m"
REFRESH_TOKEN_TTL_DAYS="7"

# ── CORS Origin (Vercel production URL) ───────────────────────────────────────
CLIENT_ORIGIN="https://jsw-mcms.vercel.app"

# ── Server ────────────────────────────────────────────────────────────────────
PORT="4000"
NODE_ENV="production"

# ── Logging ───────────────────────────────────────────────────────────────────
# Levels: error | warn | info | http | debug
LOG_LEVEL="info"
